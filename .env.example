EVIDRA_API_KEY=dev-api-key
DEMO_CLUSTER_NAME=evidra-demo

# kagent agent configuration (for A2A demo runs).
KAGENT_MODEL=gemini-2.5-flash
KAGENT_MODEL_PROVIDER=openai
KAGENT_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
