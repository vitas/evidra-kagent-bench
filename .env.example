# bench-cli direct runs (DashScope hosts deepseek-chat, qwen-plus, etc.).
LLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=
DASHSCOPE_API_KEY=
DEEPSEEK_API_KEY=

# Provider keys — models with a configured key appear as available in the UI.
GEMINI_API_KEY=
